<%- include('partials/header') %>

<main class="form-page-container">
    <h1><%= title %></h1>
    <p class="section-lead">Create a new service project and connect it with an organization to get started.</p>

    <!-- FLASH MESSAGES -->
    <% if (messages && messages.error && messages.error.length > 0) { %>
        <div class="alert alert-danger">
            <ul class="alert-list">
                <% messages.error.forEach(function(error) { %>
                    <li><%= error %></li>
                <% }); %>
            </ul>
        </div>
    <% } %>

    <% if (messages && messages.success && messages.success.length > 0) { %>
        <div class="alert alert-success">
            <ul class="alert-list">
                <% messages.success.forEach(function(msg) { %>
                    <li><%= msg %></li>
                <% }); %>
            </ul>
        </div>
    <% } %>

    <div class="form-card">
        <form action="/new-project" method="POST" class="styled-form">
            <div class="form-group">
                <label for="title">Project Title</label>
                <input 
                    type="text" 
                    id="title" 
                    name="title" 
                    placeholder="e.g., Annual Beach Clean-Up"
                    required
                    maxlength="200"
                />
            </div>

            <div class="form-group">
                <label for="organizationId">Partner Organization</label>
                <select id="organizationId" name="organizationId" required>
                    <option value="" disabled selected>Select an organization...</option>
                    <% organizations.forEach(function(org) { %>
                        <option value="<%= org.organization_id %>">
                            <%= org.name %>
                        </option>
                    <% }); %>
                </select>
            </div>

            <div class="form-group">
                <label for="location">Location</label>
                <input 
                    type="text" 
                    id="location" 
                    name="location" 
                    placeholder="e.g., Community Park, Central City"
                    required
                    maxlength="200"
                />
            </div>

            <div class="form-group">
                <label for="date">Project Date</label>
                <input 
                    type="date" 
                    id="date" 
                    name="date" 
                    required
                />
            </div>

            <div class="form-group">
                <label for="description">Description</label>
                <textarea 
                    id="description" 
                    name="description" 
                    rows="4" 
                    placeholder="Describe the goals, duties, and details for volunteers..."
                    required
                    maxlength="1000"
                ></textarea>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-primary full-width">Create Project</button>
                <a href="/projects" class="btn-outline full-width">Cancel</a>
            </div>
        </form>
    </div>
</main>

<%- include('partials/footer') %>