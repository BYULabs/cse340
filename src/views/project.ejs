<%- include('partials/header') %>

<main class="project-detail-container">
    <h1><%= title %></h1>

    <section class="project-profile-card">
        <div class="project-profile-header">
            <div class="project-profile-info">
                <h2><%= project.title %></h2>
                <div class="project-meta">
                    <% 
                        const formattedDate = new Date(project.date).toLocaleDateString(undefined, {
                            year: 'numeric',
                            month: 'long',
                            day: 'numeric'
                        });
                    %>
                    <span class="project-date">📅 <%= formattedDate %></span>
                    <span class="project-location">📍 <%= project.location %></span>
                </div>
            </div>

            <!-- Action Buttons: Edit Project and Assign Categories -->
            <div class="project-profile-actions" style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
                <a href="/edit-project/<%= project.project_id || project.id %>" class="btn-outline btn-edit-org">
                    ✏️ Edit Project
                </a>
                <a href="/project/<%= project.project_id || project.id %>/assign-categories" class="btn-outline btn-edit-org">
                    🏷️ Assign Categories
                </a>
            </div>
        </div>
        
        <div class="project-profile-body">
            <!-- Category Tags -->
            <% if (categories && categories.length > 0) { %>
                <div class="project-tags" style="display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 0.5rem;">
                    <% categories.forEach(category => { %>
                        <a href="/category/<%= category.category_id %>" class="hero-badge" style="text-decoration: none; transition: background-color 0.2s ease, color 0.2s ease; display: inline-block;">
                            <%= category.name %>
                        </a>
                    <% }); %>
                </div>
            <% } %>

            <p class="project-desc"><%= project.description %></p>
            
            <div class="project-organization-reference">
                <strong>Partner Organization:</strong> 
                <a href="/organization/<%= project.organization_id %>" class="org-link">
                    <%= project.organization_name %>
                </a>
            </div>
        </div>
    </section>
</main>

<%- include('partials/footer') %>