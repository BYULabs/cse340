<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>

    <h2>Upcoming Service Projects</h2>

    <!-- Call-to-action to create a new project -->
    <div style="margin-top: 1rem;">
        <a href="/new-project" class="btn-primary">+ Add New Project</a>
    </div>

    <ul class="projects-grid">
        <% projects.forEach(project => { %>
            <% 
                const formattedDate = new Date(project.date).toLocaleDateString(undefined, {
                    year: 'numeric',
                    month: 'short',
                    day: 'numeric'
                });
            %>
            <li>
                <div class="project-header">
                    <strong class="project-title-block">
                        <span class="meta-inline-date"><%= formattedDate %>:</span> 
                        <!-- Link to the service project details page -->
                        <a href="/project/<%= project.project_id %>" class="title-text-link">
                            <span class="title-text"><%= project.title %></span>
                        </a>
                        <!-- Link to the organization details page -->
                        <span class="meta-inline-org">
                            (<a href="/organization/<%= project.organization_id %>" class="org-inline-link"><%= project.organization_name %></a>)
                        </span>
                    </strong>
                </div>
                
                <p class="project-desc"><%= project.description %></p>
                
                <div class="project-details">
                    <span class="project-location">📍 <%= project.location %></span>
                </div>
            </li>
        <% }); %>
    </ul>
</main>

<%- include('partials/footer') %>